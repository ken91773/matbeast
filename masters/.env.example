# Mat Beast Masters - environment variables
#
# Copy this file to `.env.local` in the same folder. `.env.local` is
# gitignored so your secret values never end up in git.
#
# Prisma CLI also needs DATABASE_URL in `.env` (not `.env.local`) - the
# project script `npm run dev` reads `.env.local`, but `npx prisma ...`
# only reads `.env`. Both files are gitignored.

# --- Neon Postgres (REQUIRED) ---
# Connection string from the Neon dashboard. Should start with
# "postgresql://" and include "?sslmode=require".
DATABASE_URL=

# --- Clerk (auth, REQUIRED) ---
# From the Clerk dashboard, API keys page.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Cloudflare R2 (event file storage) ---
# Filled in later when we set up R2 for shared .matb files.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
