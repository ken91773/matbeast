{
  "name": "matbeastscore",
  "version": "1.2.10",
  "private": true,
  "description": "Mat Beast Scoreboard - quintet roster, mat control, and broadcast overlay (Windows desktop)",
  "author": "Mat Beast",
  "repository": {
    "type": "git",
    "url": "https://github.com/ken91773/matbeast.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "desktop:dev": "concurrently -k \"next dev --turbopack -p 3000\" \"wait-on tcp:3000 && electron .\"",
    "desktop:start": "concurrently -k \"next start -p 3000\" \"wait-on tcp:3000 && cross-env NODE_ENV=production electron .\"",
    "desktop:icon": "node ./scripts/generate-icon.mjs",
    "desktop:runtime": "node ./scripts/prepare-node-runtime.mjs",
    "desktop:variant-prep": "node ./scripts/variant-prep.mjs",
    "desktop:prepare-db": "node ./scripts/prepare-desktop-db.mjs",
    "desktop:build": "npm run desktop:icon && npm run desktop:runtime && npm run desktop:variant-prep && npm run db:generate && npm run desktop:prepare-db && npm run build && node ./scripts/strip-standalone-dotenv.mjs && node ./scripts/run-electron-builder.mjs --win --x64",
    "desktop:build:demo": "cross-env MATBEAST_VARIANT=demo npm run desktop:build",
    "desktop:publish": "node ./scripts/desktop-publish.mjs",
    "desktop:publish:run": "npm run desktop:icon && npm run desktop:runtime && npm run db:generate && npm run desktop:prepare-db && npm run build && node ./scripts/strip-standalone-dotenv.mjs && node ./scripts/run-electron-builder.mjs --win --x64 --publish always",
    "desktop:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/publish-release.ps1",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "node ./scripts/patch-grandiose.mjs",
    "ndi:rebuild-electron": "electron-rebuild -f -w grandiose"
  },
  "dependencies": {
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "@prisma/client": "^6.5.0",
    "@tanstack/react-query": "^5.96.2",
    "electron-updater": "^6.6.2",
    "grandiose": "github:Streampunk/grandiose#c350e0fb6e74bbf2e4b10144fee456aa1af93f47",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-grid-layout": "^2.2.3",
    "react-resizable-panels": "^4.9.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^1.3.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "png-to-ico": "^3.0.1",
    "prisma": "^6.5.0",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.matbeastscore.scoreboard",
    "productName": "Mat Beast Scoreboard",
    "electronLanguages": [
      "en-US"
    ],
    "afterPack": "./scripts/after-pack-embed-icon.js",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/@prisma/**/*",
      "!node_modules/prisma/**/*",
      "!node_modules/next/**/*",
      "!node_modules/react/**/*",
      "!node_modules/react-dom/**/*",
      "!node_modules/@next/**/*",
      "!node_modules/sharp/**/*",
      "!node_modules/tailwindcss/**/*",
      "!node_modules/@tailwindcss/**/*",
      "!node_modules/grandiose/build/Release/*.{pdb,iobj,ipdb,exp,lib}",
      "!node_modules/grandiose/build/Release/obj/**/*",
      "!node_modules/grandiose/lib/linux_arm64/**/*",
      "!node_modules/grandiose/lib/linux_x64/**/*",
      "!node_modules/grandiose/lib/mac_universal/**/*",
      "!node_modules/grandiose/lib/win_x86/**/*",
      "!node_modules/grandiose/src/**/*",
      "!node_modules/grandiose/include/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/node-runtime/matbeast-node.exe",
        "to": "node-runtime/matbeast-node.exe"
      },
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "standalone/node_modules"
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/public"
      },
      {
        "from": "build/default-data/matbeast-template.db",
        "to": "default-data/matbeast-template.db"
      },
      {
        "from": "build/variant.json",
        "to": "variant.json"
      },
      {
        "from": "build/demo-seed/sample-events",
        "to": "sample-events",
        "filter": [
          "**/*.matb"
        ]
      },
      {
        "from": "build/default-music",
        "to": "default-music",
        "filter": [
          "**/*.{mp3,m4a,aac,ogg,oga,wav,flac,webm,opus}"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "matb",
        "name": "com.matbeastscore.event",
        "description": "Mat Beast Scoreboard event file",
        "mimeType": "application/json",
        "role": "Editor",
        "icon": "build/icon.ico"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "runAfterFinish": false,
      "uninstallDisplayName": "Mat Beast Scoreboard",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Mat Beast Scoreboard",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "include": "electron/installer-cleanup.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "ken91773",
      "repo": "matbeast",
      "releaseType": "release"
    }
  }
}
