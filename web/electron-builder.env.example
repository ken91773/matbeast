# Copy to electron-builder.env (gitignored) for npm run desktop:publish
# GitHub → Settings → Developer settings → Fine-grained or classic PAT with repo scope.
GH_TOKEN=

# Windows Authenticode (Smart App Control / reputation installs)
# Use either a PFX file OR a certificate already in the Windows certificate store.
#
# PFX path (absolute recommended) + password → mapped to CSC_LINK / CSC_KEY_PASSWORD:
# WIN_CSC_LINK=C:\path\to\codesign.pfx
# WIN_CSC_KEY_PASSWORD=your-pfx-password
#
# Or signing identity name / thumbprint (see electron-builder docs for CSC_NAME):
# WIN_CSC_NAME=Your Company Name
#
# Standard CSC_* vars also work if you prefer those names.
