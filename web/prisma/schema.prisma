// Mat Beast Score — data model (Quintet / EBI-style, submission-only)
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BeltRank {
  WHITE
  BLUE
  PURPLE
  BROWN
  BLACK
}

/// Blue belt event vs purple & brown combined event
enum EventKind {
  BLUE_BELT
  PURPLE_BROWN
}

enum BracketRound {
  QUARTER_FINAL
  SEMI_FINAL
  GRAND_FINAL
}

enum EliminationMode {
  SINGLE
  DOUBLE
}

/// End of a single 4-min regulation bout or an overtime minute (submission-only)
enum BoutOutcome {
  SUBMISSION_LEFT
  SUBMISSION_RIGHT
  DRAW
}

/// Regulation 4 min vs OT 1 min periods
enum TimerPhase {
  REGULATION
  OVERTIME
}

enum FinalResultType {
  LEFT
  RIGHT
  DRAW
  NO_CONTEST
  SUBMISSION_LEFT
  SUBMISSION_RIGHT
  ESCAPE_LEFT
  ESCAPE_RIGHT
  DQ_LEFT
  DQ_RIGHT
  MANUAL
}

model Tournament {
  id                String            @id @default(cuid())
  name              String
  eliminationMode   EliminationMode   @default(SINGLE)
  maxTeams          Int               @default(8)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  events     Event[]
  scoreboard LiveScoreboardState?
  resultLogs ResultLog[]
}

model Event {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  kind         EventKind
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  teams          Team[]
  bracketMatches BracketMatch[]

  @@unique([tournamentId, kind])
}

/// Up to 8 teams per event (each saved “event file” uses one primary Event row)
model Team {
  id       String @id @default(cuid())
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name     String
  seedOrder Int   @default(0)
  /** Optional CSS color (e.g. `#ff00aa`) for bracket overlay slot backgrounds */
  overlayColor String?

  players Player[]

  homeBracketMatches BracketMatch[] @relation("HomeTeam")
  awayBracketMatches BracketMatch[] @relation("AwayTeam")
  wonBracketMatches  BracketMatch[] @relation("WinnerTeam")

  @@unique([eventId, seedOrder])
}

/// 5 primary + 2 standby; `lineupOrder` 1–7 is the predetermined Quintet order
model Player {
  id        String @id @default(cuid())
  teamId    String
  team      Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  nickname  String?
  academyName String?

  unofficialWeight Float?
  officialWeight   Float?
  heightFeet       Int?
  /// 0–11
  heightInches   Int?
  age            Int?
  beltRank       BeltRank

  /// Paths under /public/uploads/... or external URLs
  profilePhotoUrl String?
  headShotUrl     String?

  /// 1..7 for seeded lineup positions; null for overflow athletes beyond top 7.
  lineupOrder Int?

  /// Coach confirmed seed / lineup order for this slot
  lineupConfirmed Boolean @default(false)

  /// Coach confirmed weigh-in for this athlete
  weighedConfirmed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activeLeftSessions  QuintetSession[] @relation("ActiveLeftCorner")
  activeRightSessions QuintetSession[] @relation("ActiveRightCorner")

  boardLeftOf  LiveScoreboardState? @relation("BoardLeftPlayer")
  boardRightOf LiveScoreboardState? @relation("BoardRightPlayer")

  @@unique([teamId, lineupOrder])
}

/// Global athlete profiles (all events / history). Names normalized uppercase for dedup.
model MasterPlayerProfile {
  id        String @id @default(cuid())
  firstName String
  lastName  String
  nickname  String?
  academyName String?

  unofficialWeight Float?
  heightFeet       Int?
  heightInches     Int?
  age              Int?
  beltRank         BeltRank

  profilePhotoUrl String?
  headShotUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Mat Beast Masters cloud row id. Set after first push or pull; used
  /// for direct DELETE/PATCH against the cloud. Null = never synced.
  cloudId String?

  @@unique([firstName, lastName])
}

/// Global team name list (all events / dashboards). Names normalized uppercase for dedup.
model MasterTeamName {
  id   String @id @default(cuid())
  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Mat Beast Masters cloud row id. Set after first push or pull. Null
  /// = local-only (never synced to cloud yet).
  cloudId String?
}

/// Single-row config for cloud sync against the Mat Beast Masters service.
/// `id` is always the literal "default" — exactly one row exists.
///
/// IMPORTANT: this table is created lazily by ensureCloudConfigTable() at
/// runtime, NOT by the bundled seed template. Older user DBs that predate
/// the cloud feature get the table on first cloud-related API call.
model CloudConfig {
  id                  String    @id @default("default")
  /// Plaintext desktop token (mbk_...). Empty string = not linked.
  desktopToken        String    @default("")
  /// Base URL of the cloud service. Defaults to production deployment.
  cloudBaseUrl        String    @default("https://matbeast-masters.vercel.app")
  /// True when sync is enabled. False = pretend the cloud doesn't exist.
  syncEnabled         Boolean   @default(true)
  /// Last successful master player profile pull completion time.
  lastProfilesPullAt  DateTime?
  /// Last successful master team name pull completion time.
  lastTeamNamesPullAt DateTime?
  /// Last sync error message (cleared automatically on next success).
  lastSyncError       String?

  updatedAt DateTime @updatedAt
}

/// Links a local Tournament to a cloud event in Mat Beast Masters.
///
/// One row per locally-open tournament that the user has linked to the
/// cloud (either by "Open from cloud" or "Upload current to cloud").
/// Tournaments without a row here are "local only" — saves go to disk,
/// badge shows LOCAL ONLY.
///
/// Lazily created by ensureCloudEventLinkTable() for legacy user DBs.
///
/// Sync state fields (used to compute the header badge):
///   baseVersion     — last cloud version we pushed OR pulled. The
///                     expectedVersion header on PUT. If cloud moved
///                     past this, we're in CONFLICT.
///   lastSyncedSha   — sha256 of the blob after the last successful
///                     push or pull. Comparing with currentLocalSha
///                     tells us NOT-SYNCED vs SYNCED.
///   currentLocalSha — sha256 of what the desktop most recently saved.
///                     Updated on every save of this tournament.
///   pendingPushAt   — non-null when a push is queued/retrying.
///   lastError       — most recent cloud error string (for the badge
///                     tooltip + force-sync dialog).
model CloudEventLink {
  tournamentId     String    @id
  cloudEventId     String    @unique
  baseVersion      Int       @default(0)
  lastSyncedSha    String?
  currentLocalSha  String?
  /// Size in bytes of the blob we last synced (for "Size" display).
  lastSyncedBytes  Int       @default(0)
  lastPulledAt     DateTime?
  lastPushedAt     DateTime?
  pendingPushAt    DateTime?
  lastError        String?
  /// Path of the local mirror .matb file (offline cache). Set by the
  /// sync helper when it saves a copy under %LOCALAPPDATA%.
  localMirrorPath  String?
}

/// FIFO queue of master-list mutations the desktop wants to push to the
/// cloud. Drained by the cloud sync helper. Successful ops are deleted;
/// permanently-failing ops stay with `attempts >= 5` and a `lastError`.
///
/// Lazily created by ensureMasterCloudOutboxTable() — same self-heal
/// pattern as MasterPlayerProfile / MasterTeamName.
model MasterCloudOutbox {
  id            String    @id @default(cuid())
  /// One of:
  ///   "team-name.upsert"   payload: { name }
  ///   "team-name.delete"   payload: { name }
  ///   "profile.upsert"     payload: { firstName, lastName, ...fields }
  ///   "profile.delete"     payload: { id }   // cloud profile id
  kind          String
  /// JSON-encoded payload. Shape depends on `kind`.
  payloadJson   String
  createdAt     DateTime  @default(now())
  attempts      Int       @default(0)
  lastError     String?
  lastAttemptAt DateTime?

  @@index([createdAt])
}

/// Live mat state per tournament (event file)
model LiveScoreboardState {
  tournamentId String      @id
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  leftPlayerId  String? @unique
  rightPlayerId String? @unique
  leftPlayer    Player? @relation("BoardLeftPlayer", fields: [leftPlayerId], references: [id], onDelete: SetNull)
  rightPlayer   Player? @relation("BoardRightPlayer", fields: [rightPlayerId], references: [id], onDelete: SetNull)

  roundLabel String @default("Quarter Finals")
  currentRosterFileName String @default("UNTITLED")
  customLeftName  String?
  customLeftTeamName String?
  customRightName String?
  customRightTeamName String?

  finalSaved      Boolean         @default(false)
  finalResultType FinalResultType?
  finalWinnerName String?
  finalResultLogId String?
  /// JSON snapshot of board state right before FINAL save; used by UNSAVE restore.
  preFinalStateJson String?

  timerSeconds Int       @default(240)
  timerRunning Boolean   @default(false)
  timerEndsAt  DateTime?

  timerPhase        TimerPhase @default(REGULATION)
  overtimeIndex     Int        @default(0)
  overtimeWinsLeft  Int        @default(0)
  overtimeWinsRight Int        @default(0)

  leftEliminatedCount  Int @default(0)
  rightEliminatedCount Int @default(0)
  sound10Enabled       Boolean @default(true)
  sound0Enabled        Boolean @default(true)
  sound10PlayNonce     Int @default(0)
  sound0PlayNonce      Int @default(0)

  updatedAt DateTime @updatedAt
}

model ResultLog {
  id String @id @default(cuid())
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  rosterFileName String @default("UNTITLED")
  roundLabel String
  leftName String
  rightName String
  leftTeamName String?
  rightTeamName String?
  resultType FinalResultType
  winnerName String?
  isManual Boolean @default(false)
  manualDate String?
  manualTime String?
  /// One-line finals text: "M/D/YYYY HH:mm WINNER def. LOSER"
  finalSummaryLine String?
  createdAt DateTime @default(now())

  @@index([tournamentId, createdAt])
}

model BracketMatch {
  id           String        @id @default(cuid())
  eventId      String
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  round        BracketRound
  bracketIndex Int           @default(0)

  homeTeamId String
  awayTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)

  winnerTeamId String?
  winnerTeam   Team?   @relation("WinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)

  quintetSessions QuintetSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId, round])
}

model QuintetSession {
  id             String       @id @default(cuid())
  bracketMatchId String
  bracketMatch   BracketMatch @relation(fields: [bracketMatchId], references: [id], onDelete: Cascade)

  leftPlayerId  String?
  rightPlayerId String?
  leftPlayer    Player? @relation("ActiveLeftCorner", fields: [leftPlayerId], references: [id], onDelete: SetNull)
  rightPlayer   Player? @relation("ActiveRightCorner", fields: [rightPlayerId], references: [id], onDelete: SetNull)

  leftEliminatedSlots  String @default("[]")
  rightEliminatedSlots String @default("[]")

  timerSeconds Int       @default(240)
  timerRunning Boolean   @default(false)
  timerPhase   TimerPhase @default(REGULATION)
  overtimeIndex Int      @default(0)
  overtimeWinsLeft  Int  @default(0)
  overtimeWinsRight Int @default(0)

  bouts BoutLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BoutLog {
  id               String         @id @default(cuid())
  quintetSessionId String
  quintetSession   QuintetSession @relation(fields: [quintetSessionId], references: [id], onDelete: Cascade)
  outcome          BoutOutcome
  phase            TimerPhase
  overtimeIndex    Int            @default(0)
  recordedAt       DateTime       @default(now())
}
